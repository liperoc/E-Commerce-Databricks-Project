   "source": [
    "%sql\n",
    "CREATE OR REPLACE TABLE gold_sales_country AS\n",
    "\n",
    "SELECT\n",
    "\n",
    "Country,\n",
    "\n",
    "SUM(TotalAmount) AS TotalSales,\n",
    "\n",
    "SUM(Quantity) AS ItemsSold,\n",
    "\n",
    "COUNT(CustomerID) AS Customers\n",
    "\n",
    "FROM silver_sales\n",
    "\n",
    "GROUP BY Country\n",
    "\n",
    "ORDER BY TotalSales DESC;"
   ]
  }
