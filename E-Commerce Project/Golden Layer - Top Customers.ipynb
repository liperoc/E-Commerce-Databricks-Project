   "source": [
    "%sql\n",
    "CREATE OR REPLACE TABLE gold_top_customers AS\n",
    "\n",
    "SELECT\n",
    "\n",
    "CustomerID,\n",
    "\n",
    "ROUND(SUM(TotalAmount),2) AS TotalSpent,\n",
    "\n",
    "COUNT(DISTINCT InvoiceNo) Orders\n",
    "\n",
    "FROM silver_sales\n",
    "\n",
    "GROUP BY CustomerID\n",
    "\n",
    "ORDER BY TotalSpent DESC;"
   ]
  }
 ],
